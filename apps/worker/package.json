{
  "name": "@eduforge/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "build": "tsup src/index.ts --format esm --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@eduforge/ai": "workspace:*",
    "@eduforge/config": "workspace:*",
    "@eduforge/db": "workspace:*",
    "@eduforge/schemas": "workspace:*",
    "archiver": "^7.0.1",
    "bullmq": "^5.34.6",
    "ioredis": "5.10.1",
    "mammoth": "^1.8.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.49.1",
    "unpdf": "^0.12.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3"
  }
}
