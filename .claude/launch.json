{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@eduforge/api", "dev"],
      "port": 3333
    },
    {
      "name": "worker",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@eduforge/worker", "dev"],
      "port": 3334
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@eduforge/web", "exec", "next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "admin",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@eduforge/admin", "dev"],
      "port": 3001
    },
    {
      "name": "runtime",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@eduforge/runtime", "exec", "vite"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
