{
  "name": "@eduforge/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "build": "prisma generate && tsup src/index.ts --format cjs,esm --dts --clean --sourcemap",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@eduforge/schemas": "workspace:*",
    "@eduforge/ui": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "^5.22.0"
  }
}
