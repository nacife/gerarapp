{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET_UPLOADS",
    "S3_BUCKET_APPS",
    "S3_BUCKET_WORM",
    "JWT_SECRET",
    "REFRESH_TOKEN_PEPPER",
    "AI_PROVIDER",
    "ANTHROPIC_API_KEY",
    "AI_MODEL_STRUCTURE",
    "AI_MODEL_INTERACTIONS",
    "OCR_PROVIDER",
    "MAILER",
    "SMTP_URL",
    "APP_BASE_URL",
    "RUNTIME_BASE_URL",
    "ADMIN_BASE_URL",
    "API_PORT",
    "WORKER_PORT",
    "INPI_GRU_FEE_CENTS",
    "INPI_SERVICE_FEE_CENTS"
  ],
  "tasks": {
    "db:generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
