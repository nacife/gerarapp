# ─────────────────────────────────────────────────────────────
# EduForge — variáveis de ambiente (PRD §0.7)
# Copie para `.env` e ajuste conforme necessário. A aplicação NÃO
# sobe com env inválida (validação por Zod em packages/config).
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# Banco de dados (Postgres 16 + pgvector)
# DATABASE_URL: role restrita usada em runtime (sem UPDATE/DELETE nas tabelas WORM).
DATABASE_URL=postgresql://eduforge_app:eduforge_app@localhost:5432/eduforge?schema=public
# DIRECT_DATABASE_URL: role dona das tabelas, só para `prisma migrate`/`db seed`.
DIRECT_DATABASE_URL=postgresql://eduforge:eduforge@localhost:5432/eduforge?schema=public

# Redis (filas BullMQ + sessões)
REDIS_URL=redis://localhost:6379

# Armazenamento de objetos (MinIO local, compatível com S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=eduforge
S3_SECRET_KEY=eduforge123
S3_BUCKET_UPLOADS=eduforge-uploads
S3_BUCKET_APPS=eduforge-apps
S3_BUCKET_WORM=eduforge-worm

# Autenticação (mín. 32 caracteres cada — troque em produção)
JWT_SECRET=dev-jwt-secret-change-me-please-0123456789abcdef
REFRESH_TOKEN_PEPPER=dev-refresh-token-pepper-change-me-0123456789ab
AUTH_ENCRYPTION_KEY=dev-auth-encryption-key-change-me-0123456789ab

# IA (mock em dev; anthropic em produção)
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
AI_MODEL_STRUCTURE=claude-sonnet-5
AI_MODEL_INTERACTIONS=claude-sonnet-5

# OCR e e-mail
OCR_PROVIDER=tesseract
MAILER=console
SMTP_URL=

# URLs públicas
APP_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3001
RUNTIME_BASE_URL=http://localhost:5173

# URL pública da API para os painéis (inlinada pelo Next no browser)
NEXT_PUBLIC_API_URL=http://localhost:3333
# URL do app do criador, usada pelo admin para abrir a sessão de suporte (impersonação, RF-12)
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
# URL da API para o runtime (Vite)
VITE_API_URL=http://localhost:3333

# Portas dos serviços de backend
API_PORT=3333
WORKER_PORT=3334

# INPI — taxa da GRU código 730 em centavos (parametrizado, nunca hard-coded)
INPI_GRU_FEE_CENTS=21000
# Honorários do Registro Assistido (RF-17), repassados separados da GRU
INPI_SERVICE_FEE_CENTS=29700
